//Include Libraries
#include <Servo.h>
#include <LiquidCrystal.h>

//Initialize Libraries and Declare Variables
Servo pan;
Servo arm;
const int rs = 12, en = 11, d4 = 5, d5 = 4, d6 = 3, d7 = 2;
LiquidCrystal lcd(rs, en, d4, d5, d6, d7);
int pos = 0;
String emotes[] = {"plain", "robot", "tears", "dizzy", "happy", "wink", "dead", "wave"};

void setup() {
  Serial.begin(9600);
  pan.attach(10);
  pan.write(20);
  arm.attach(9);
  lcd.begin(16,2);
}

void loop() {
  if (Serial.available()) {

    //Process 'Pan' Servo
    String data = Serial.readStringUntil('\n');
    int comma = data.indexOf(',');
    int x = data.substring(0, comma).toInt();
    int panAngle = map(x, 0, 320, 180, 0);
    pan.write(panAngle);    

  }
  //Process Emotion Input
  int random = rand() % 8;
  if(millis() % 2000 == 0) mood(emotes[random]);
}

//Set Face to Plain
void plain(){
  lcd.setCursor(0,0);
  lcd.print("(  B  )  (  B  )");
  lcd.setCursor(0,1);
  lcd.print("----------------");
  lcd.setCursor(0,0);
}

//Set Face to Robot
void robot(){
  lcd.setCursor(0,0);
  lcd.print("[  o  ]  [  o  ]");
  lcd.setCursor(0,1);
  lcd.print("================");
  lcd.setCursor(0,0);
}

//Set Face to Tears
void tears(){
  lcd.setCursor(0,0);
  lcd.print("(  T  )  (  T  )");
  lcd.setCursor(0,1);
  lcd.print("   ||       ||  ");
  lcd.setCursor(0,0);
}

//Set Face to Dizzy
void dizzy(){
  lcd.setCursor(0,0);
  lcd.print("(  @  )  (  @  )");
  lcd.setCursor(0,1);
  lcd.print("________________");
  lcd.setCursor(0,0);
}

//Set Face to Happy
void happy(){
  lcd.setCursor(0,0);
  lcd.print("(  ^  )  (  ^  )");
  lcd.setCursor(0,1);
  lcd.print("~~~~~~~~~~~~~~~~~~");
  lcd.setCursor(0,0);
}

//Set Face to Wink
void wink(){
  lcd.setCursor(0,0);
  lcd.print("(  ^  )  (  -  )");
  lcd.setCursor(0,1);
  lcd.print("----------------");
  lcd.setCursor(0,0);
}

//Set Face to Dead
void dead(){
  lcd.setCursor(0,0);
  lcd.print("(  X  )  (  X  )");
  lcd.setCursor(0,1);
  lcd.print("________________");
  lcd.setCursor(0,0);
}

//Wave the arm
void wave(){
  for(pos = 0; pos <= 90; pos++){
    arm.write(pos);
    delay(5);
  }
  for(int i = 0; i < 3; i++){
    for(pos = 90; pos <= 135; pos++){
      arm.write(pos);
     delay(5);
    }
    for(pos = 135; pos >= 90; pos--){
      arm.write(pos);
      delay(5);
    }
  }
  for(pos = 90; pos >= 0; pos--){
    arm.write(pos);
    delay(5);
  }
}

//Emote
void mood(String emo){
  if(emo == "plain"){
    plain();
  } else if(emo == "robot"){
    robot();
  } else if(emo == "tears"){
    tears();
  } else if(emo == "dizzy"){
    dizzy();
  } else if(emo == "happy"){
    happy();
  } else if(emo == "wink"){
    wink();
  } else if(emo == "dead"){
    dead();
  } else if(emo == "wave"){
    wave();
  }
  emo = " ";
}
